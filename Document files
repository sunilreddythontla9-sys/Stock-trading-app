📄 routes/trade.js

const router = require("express").Router();
const Transaction = require("../models/Transaction");
const User = require("../models/User");

// BUY
router.post("/buy", async (req, res) => {
  const { userId, stock, quantity, price } = req.body;
  const user = await User.findById(userId);

  const cost = quantity * price;

  if (user.wallet < cost)
    return res.status(400).send("Insufficient balance");

  user.wallet -= cost;
  await user.save();

  const tx = new Transaction({ userId, stock, quantity, price, type: "buy" });
  await tx.save();

  res.json(tx);
});

// SELL
router.post("/sell", async (req, res) => {
  const { userId, stock, quantity, price } = req.body;
  const user = await User.findById(userId);

  const gain = quantity * price;
  user.wallet += gain;
  await user.save();

  const tx = new Transaction({ userId, stock, quantity, price, type: "sell" });
  await tx.save();

  res.json(tx);
});

// PORTFOLIO
router.get("/portfolio/:userId", async (req, res) => {
  const tx = await Transaction.find({ userId: req.params.userId });
  res.json(tx);
});

module.exports = router;


