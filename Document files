import { useState } from "react";
import axios from "axios";

export default function Dashboard() {
  const [symbol, setSymbol] = useState("");
  const [price, setPrice] = useState(0);
  const [qty, setQty] = useState(1);

  const user = JSON.parse(localStorage.getItem("user"));

  const getStock = async () => {
    const res = await axios.get(`http://localhost:5000/api/stocks/${symbol}`);
    const p = res.data["Global Quote"]["05. price"];
    setPrice(p);
  };

  const buy = async () => {
    await axios.post("http://localhost:5000/api/trade/buy", {
      userId: user._id,
      stock: symbol,
      quantity: qty,
      price
    });
    alert("Bought!");
  };

  return (
    <div>
      <h2>Dashboard</h2>

      <input placeholder="Stock Symbol" onChange={e => setSymbol(e.target.value)} />
      <button onClick={getStock}>Get Price</button>

      <h3>Price: {price}</h3>

      <input type="number" onChange={e => setQty(e.target.value)} />
      <button onClick={buy}>Buy</button>
    </div>
  );
}


